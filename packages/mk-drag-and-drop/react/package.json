{
  "name": "@mk-drag-and-drop/react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drag-provider": {
      "types": "./dist/drag-provider.d.ts",
      "import": "./dist/drag-provider.js"
    },
    "./use-drag-handle": {
      "types": "./dist/hooks/use-drag-handle.d.ts",
      "import": "./dist/hooks/use-drag-handle.js"
    },
    "./use-draggable": {
      "types": "./dist/hooks/use-draggable.d.ts",
      "import": "./dist/hooks/use-draggable.js"
    },
    "./use-droppable": {
      "types": "./dist/hooks/use-droppable.d.ts",
      "import": "./dist/hooks/use-droppable.js"
    },
    "./compose-refs": {
      "types": "./dist/utils/compose-refs.d.ts",
      "import": "./dist/utils/compose-refs.js"
    },
    "./use-sortable": {
      "types": "./dist/hooks/use-sortable.d.ts",
      "import": "./dist/hooks/use-sortable.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@mk-drag-and-drop/dom": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "eslint": "^8.57.0",
    "react": "^19.2.7",
    "typescript": "5.5.4"
  }
}
