{
  "name": "@mk-drag-and-drop/react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drag-provider": {
      "types": "./dist/drag-provider.d.ts",
      "import": "./dist/drag-provider.js"
    },
    "./use-drag-handle": {
      "types": "./dist/useDragHandle.d.ts",
      "import": "./dist/useDragHandle.js"
    },
    "./use-draggable": {
      "types": "./dist/useDraggable.d.ts",
      "import": "./dist/useDraggable.js"
    },
    "./use-droppable": {
      "types": "./dist/useDroppable.d.ts",
      "import": "./dist/useDroppable.js"
    },
    "./use-sortable": {
      "types": "./dist/useSortable.d.ts",
      "import": "./dist/useSortable.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@mk-drag-and-drop/core": "workspace:*",
    "@mk-drag-and-drop/dom": "workspace:*",
    "@mk-drag-and-drop/sortable": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "eslint": "^8.57.0",
    "react": "^19.2.7",
    "typescript": "5.5.4"
  }
}
