{
  "name": "@mk-drag-and-drop/react",
  "version": "0.2.0",
  "description": "React hooks and provider for the mk drag-and-drop DOM runtime.",
  "license": "MIT",
  "homepage": "https://mkramer.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkramerdev/mk-drag-and-drop.git",
    "directory": "packages/mk-drag-and-drop/react"
  },
  "bugs": {
    "url": "https://github.com/mkramerdev/mk-drag-and-drop/issues"
  },
  "keywords": [
    "drag-and-drop",
    "dnd",
    "sortable",
    "react",
    "hooks",
    "headless",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mk-drag-and-drop/dom": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^2.1.9",
    "typescript": "5.5.4"
  }
}
